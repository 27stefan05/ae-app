# Kopiere diese Datei zu ".env" und trage dort deine eigenen Werte ein.
# ".env" wird automatisch geladen und darf niemals ins Git-Repository committet werden.

# Hash des Login-Passworts fuer /einstellungen.
# Erzeugen mit: python hash_password.py
# Ohne diese Variable gilt weiterhin das Standardpasswort "test".
ADMIN_PASSWORD_HASH=

# Optional: fester Secret Key statt automatisch generiertem (normalerweise nicht noetig).
SECRET_KEY=

# Pfad zur externen SSD (oder einem anderen Verzeichnis), auf das taeglich zusaetzlich
# ein Datenbank-Backup kopiert werden soll. Ohne diese Variable wird nur lokal
# gesichert (instance/backups/). Beispiel Linux: /media/uniper/BACKUP-SSD
BACKUP_DIR=
